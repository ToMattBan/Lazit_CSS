{
  "name": "lazit-css",
  "version": "1.0.0",
  "description": "A tool, like a hammer, but for managing CSS. It's based on the Inverted Triangle Architecture",
  "type": "module",
  "bin": {
    "lazit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "lightningcss": "^1.31.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.4",
    "csstype": "^3.2.3",
    "typescript": "^5.9.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./public/style.min.css"
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "keywords": [
    "css",
    "laz",
    "lazit",
    "lazit-css",
    "lazitcss",
    "lazit_css",
    "it",
    "myit",
    "my-itcss",
    "sass",
    "tool",
    "css-framework",
    "utility-css",
    "css-generator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ToMattBan/Lazit_CSS.git"
  },
  "author": "ToMatt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ToMattBan/Lazit_CSS/issues"
  },
  "homepage": "https://github.com/ToMattBan/Lazit_CSS#readme"
}